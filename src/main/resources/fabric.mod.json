{
  "schemaVersion": 1,
  "id": "smashcraft",
  "version": "${version}",
  "name": "Smash Craft",
  "description": "A Super Smash Bros mechanic in Minecraft.",
  "authors": [
    "DaManMikey"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "CC0-1.0",
  "icon": "assets/smashcraft/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.smashcraft.SmashCraft"
    ],
    "client": [
      "net.smashcraft.client.SmashCraftClient"
    ]
  },
  "mixins": [
    "smashcraft.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.7",
    "minecraft": ">=1.20.4",
    "java": ">=17",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
}
